{
  "permissions": {
    "allow": [
      "Bash(git *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "cd /c/Users/jasserk/Desktop/Doctor && git add -A && git diff --cached --quiet || (git commit -m \"auto: save\" && git push origin main)",
            "timeout": 30,
            "statusMessage": "Saving and pushing to GitHub..."
          }
        ]
      }
    ]
  }
}
